psql path=.psqlrc start_line=1 end_line=38
\set USERNAME `whoami`

-- Prompt: bold red for superuser, bold cyan for others
\if :USERNAME = 'postgres'
    \set PROMPT1 '%[%033[1;31m%]%n@%/%# %[%033[0m%]%R%# '
\else
    \set PROMPT1 '%[%033[1;36m%]%n@%/%# %[%033[0m%]%R%# '
\endif

-- Show NULLs as [NULL]
\pset null '[NULL]'

-- Use expanded table format automatically when needed
\x auto

-- Verbose error reports
\set VERBOSITY verbose

-- Per-database history file
\set HISTFILE ~/.psql_history-:DBNAME

-- Only store duplicate commands once in history
\set HISTCONTROL ignoredups

-- Autocomplete keywords in upper-case
\set COMP_KEYWORD_CASE upper

-- Reference: https://thoughtbot.com/blog/improving-the-command-line-postgres-experience

-- Show timing for each query
\timing

-- Display line numbers in query results
\pset linestyle unicode
\pset border 2

-- Show more context in error messages
\set SHOW_CONTEXT always

-- Enable tab completion for file paths
\set COMP_FILE_CASE sensitive

-- Highlight matching parentheses in queries (if supported)
\set HISTSIZE 10000

-- Show connection info at startup
\echo 'Connected to: ' :DBNAME ' as ' :USERNAME ' on ' :HOST
